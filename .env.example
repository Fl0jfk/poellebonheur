# Configuration AWS S3
AWS_ACCESS_KEY_ID=VOTRE_ACCESS_KEY_ICI
AWS_SECRET_ACCESS_KEY=VOTRE_SECRET_KEY_ICI
AWS_REGION=eu-west-3

# Nom du bucket S3 (doit exister et être configuré)
S3_BUCKET_NAME=nusha-traiteur-data

# Secret JWT (chaîne aléatoire longue)
JWT_SECRET=changez-moi-avec-une-chaine-tres-longue-et-aleatoire

# Hash bcrypt du mot de passe admin
# Pour générer : cargo run --bin gen-hash -- "votre-mot-de-passe"
# Ou avec Python : python3 -c "import bcrypt; print(bcrypt.hashpw(b'monmotdepasse', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$

# Port du serveur (optionnel, défaut 3000)
PORT=3000
